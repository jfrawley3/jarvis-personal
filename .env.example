# === REQUIRED ===
ANTHROPIC_API_KEY=sk-ant-...
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_USER_ID=your_telegram_user_id

# === SETTINGS ===
DATABASE_PATH=jarvis.db
DASHBOARD_PORT=8000
CURRENCY=USD
LOCATION=New York
TIMEZONE=US/Eastern

